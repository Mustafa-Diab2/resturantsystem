NODE_ENV=development
PORT=5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=servex
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=servex_jwt_super_secret_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=servex_refresh_super_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
